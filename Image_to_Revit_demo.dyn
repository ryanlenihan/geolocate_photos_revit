    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB import Structure\r\n\r\n# Dynamo unwrap support (safe even if not used)\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ndef first(x):\r\n    return x[0] if isinstance(x, list) else x\r\n\r\ndef as_float(x):\r\n    return float(first(x))\r\n\r\ndef get_type_name(symbol):\r\n    # Avoid symbol.Name (can fail in Dynamo); use built-in parameter instead\r\n    p = symbol.get_Parameter(BuiltInParameter.SYMBOL_NAME_PARAM)\r\n    return p.AsString() if p else None\r\n\r\ndef get_family_name(symbol):\r\n    # Avoid symbol.Family.Name; use built-in parameter instead\r\n    p = symbol.get_Parameter(BuiltInParameter.ALL_MODEL_FAMILY_NAME)\r\n    return p.AsString() if p else None\r\n\r\n# --- Inputs ---\r\neasting_m   = as_float(IN[0])\r\nnorthing_m  = as_float(IN[1])\r\nelevation_m = as_float(IN[2])\r\n\r\nfamily_or_type = first(IN[3])\r\ntype_name_in   = first(IN[4]) if len(IN) > 4 else None\r\n\r\n# --- Convert metres -> internal feet ---\r\ne_ft = UnitUtils.ConvertToInternalUnits(easting_m, UnitTypeId.Meters)\r\nn_ft = UnitUtils.ConvertToInternalUnits(northing_m, UnitTypeId.Meters)\r\nz_ft = UnitUtils.ConvertToInternalUnits(elevation_m, UnitTypeId.Meters)\r\n\r\nshared_pt = XYZ(e_ft, n_ft, z_ft)\r\n\r\n# --- Shared -> Project transform (same approach as your macro) ---\r\ntransform = doc.ActiveProjectLocation.GetTotalTransform()\r\nproject_pt = transform.OfPoint(shared_pt)\r\n\r\n# --- Resolve FamilySymbol ---\r\nsymbol = None\r\n\r\n# Case A: user passed a Dynamo Family Type node\r\ntry:\r\n    unwrapped = UnwrapElement(family_or_type)\r\n    if isinstance(unwrapped, FamilySymbol):\r\n        symbol = unwrapped\r\nexcept:\r\n    pass\r\n\r\n# Case B: user passed family/type names as strings\r\nif symbol is None:\r\n    fam_name_in = str(family_or_type) if family_or_type is not None else None\r\n    typ_name_in = str(type_name_in) if type_name_in is not None else None\r\n\r\n    if fam_name_in and typ_name_in:\r\n        for fs in FilteredElementCollector(doc).OfClass(FamilySymbol):\r\n            fn = get_family_name(fs)\r\n            tn = get_type_name(fs)\r\n            if fn == fam_name_in and tn == typ_name_in:\r\n                symbol = fs\r\n                break\r\n\r\n# --- Place instance ---\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ninst = None\r\nmsg = None\r\n\r\nif symbol is None:\r\n    msg = \"ERROR: Could not resolve FamilySymbol. Use a 'Family Types' node or provide exact family/type strings.\"\r\nelse:\r\n    if not symbol.IsActive:\r\n        symbol.Activate()\r\n\r\n    inst = doc.Create.NewFamilyInstance(\r\n        project_pt,\r\n        symbol,\r\n        Structure.StructuralType.NonStructural\r\n    )\r\n    msg = \"Placed OK\"\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\n# Output both for debugging\r\nOUT = (inst, msg, project_pt)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "4cf49c7c7da944cf9197deb4ba563f17",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "db3606613f2946d987cefffe886b6bdd",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
